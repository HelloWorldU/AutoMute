/build/
/out/
*.exe
*.obj
*.o
*.a
*.lib
*.dll
*.pdb

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# IDE / editor
.vs/
.idea/
*.user
# .vscode 杂项忽略，但共享格式化等团队配置入库（仿 vllm）
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
Thumbs.db
desktop.ini

# Models / large assets (声纹模型等，不入库)
*.onnx
*.bin
/models/

# 第三方库一律不入库（体积大或可重新获取）；用 scripts/fetch-deps.ps1 一键拉取
/third_party/

# 前端（Vue+Vite）依赖与构建产物不入库。源码在 frontend/src 入库；
# 构建产物经 scripts/embed-frontend.mjs 嵌进 automute/gui_html.cpp（生成物，已入库）。
/frontend/node_modules/
/frontend/dist/
